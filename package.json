{
  "name": "hq-vault",
  "version": "0.1.0",
  "description": "Agent-native encrypted credential vault with libsodium encryption",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hq-vault": "dist/cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/fix-libsodium-esm.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/commander": "^2.12.0",
    "commander": "^14.0.3",
    "libsodium-wrappers-sumo": "^0.7.15",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^22.13.4",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
